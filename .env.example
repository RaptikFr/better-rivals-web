# Copier ce fichier en .env.local et renseigner les valeurs.
# .env.local est ignoré par Git (voir .gitignore) — n'y mets jamais de secret ici.

# --- Supabase (obligatoire) ---
# URL du projet et clés. La service role key est SECRÈTE : serveur uniquement.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- URL du site (optionnel) ---
# Surcharge l'URL canonique (SEO, e-mails, Open Graph). Défaut : https://better-rivals-fh6.org
NEXT_PUBLIC_SITE_URL=

# --- Resend — e-mails (optionnel) ---
# Sans clé, les e-mails sont silencieusement désactivés (dev/local OK).
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- Cloudflare Turnstile — captcha contact (optionnel) ---
# Sans la clé secrète, le captcha est désactivé côté serveur.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Upstash Redis — rate-limit partagé (optionnel) ---
# Sans ces deux variables, repli automatique sur un compteur en mémoire.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Cron récap hebdomadaire (optionnel) ---
# Secret partagé protégeant /api/cron/weekly-recap.
CRON_SECRET=

# --- Discord — annonces des nouveaux nº1 (optionnel) ---
# URL de webhook d'un salon Discord (Paramètres du salon → Intégrations →
# Webhooks). Sans cette variable, aucune annonce n'est envoyée (no-op).
DISCORD_WEBHOOK_URL=
